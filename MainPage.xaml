<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="streetfood.MainPage">

    <VerticalStackLayout Padding="20">

        <Label
            x:Name="titleLabel"
            Text="Street Food Vinh Khanh"
            FontSize="26"
            HorizontalOptions="Center"/>

        <Label
            x:Name="infoLabel"
            Text="Đang kiểm tra vị trí..."
            FontSize="16"
            Margin="0,10,0,10"/>
        
        
        
        <Button
    x:Name="replayButton"
    Text="repeat"
    IsVisible="False"
    Clicked="OnReplayClicked"/>

        <Label
    Text="Quan duoc quan tam"
    FontSize="20"
    FontAttributes="Bold"
    Margin="0,350,0,0"/>

        <CollectionView x:Name="popularList"
                        HeightRequest="200">
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label
                        Text="{Binding Name}"
                        FontSize="16"/>

                        <Label
                        Grid.Column="1"
                        Text="{Binding Distance,StringFormat='{0:0} m'}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        

    </VerticalStackLayout>

</ContentPage>