<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="streetfood.MainPage">

    <Grid>

        <!-- Nội dung chính -->
        <VerticalStackLayout Padding="20">

            <Label
            Text="Street Food Vinh Khanh"
            FontSize="26"
            HorizontalOptions="Center"/>

            <Label
            x:Name="infoLabel"
            Text="Đang kiểm tra vị trí..."
            FontSize="16"
            Margin="0,10,0,10"/>

            <HorizontalStackLayout Spacing="10">

                <Button
        x:Name="replayButton"
        Text="🔁"
        WidthRequest="60"
        HeightRequest="40"
        IsVisible="False"
        Clicked="OnReplayClicked"/>

                <Button
        x:Name="stopButton"
        Text="⏹"
        WidthRequest="60"
        HeightRequest="40"
        IsVisible="False"
        Clicked="OnStopClicked"/>

            </HorizontalStackLayout>
            <Label
            Text="Quan duoc quan tam"
            FontSize="20"
            FontAttributes="Bold"
            Margin="0,30,0,0"/>

            <CollectionView x:Name="popularList"
                        HeightRequest="200"/>
        </VerticalStackLayout>

        <!-- 🔴 NÚT TRÒN -->
        <Frame
        WidthRequest="25"
        HeightRequest="25"
        CornerRadius="0"
        BackgroundColor="White"
        Padding="0"
        HasShadow="True"
        HorizontalOptions="End"
        VerticalOptions="Start"
        Margin="0,-2,10,0">

            <Label
            Text="🌐"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            TextColor="White"
            FontSize="20">

                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChooseLanguage"/>
                </Label.GestureRecognizers>

            </Label>

        </Frame>

    </Grid>

</ContentPage>